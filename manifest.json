{
  "manifest_version": 3,
  "name": "语雀知识库下载 - yuque-dl",
  "version": "1.0.0",
  "description": "将语雀知识库下载为本地 Markdown 文件 (ZIP格式)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://www.yuque.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "语雀下载器",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.yuque.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/jszip.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
